{"root":{"data":{"id":"dh7sg4on9a80","created":1774028018228,"text":"python"},"children":[{"data":{"id":"dh7shylxl4w0","created":1774028161732,"text":"第三章节","layout_mind_offset":{"x":152.9999952167277,"y":103.4999947920445},"expandState":"expand"},"children":[{"data":{"id":"dhdqrv448mw0","created":1774632655286,"text":"if语句","expandState":"collapse","layout_right_offset":{"x":325.2499798573559,"y":10.000000074506033}},"children":[{"data":{"id":"dhdqs3hs3x40","created":1774632673526,"text":"if语句的基本格式","expandState":"expand","layout_right_offset":{"x":0.833333275384291,"y":13.749998826533727}},"children":[{"data":{"id":"dhdqz1nnzwg0","created":1774633218078,"text":"if 条件:\n\t   执行操作\nelif 条件:\n\t   执行操作\nelse:\n\t   执行操作\n(elif 是 else if的缩写)","layout_right_offset":{"x":29.166664638453028,"y":-24.999998261531516}},"children":[]}]},{"data":{"id":"dhe2zrfpaw80","created":1774667127512,"text":"嵌套使用"},"children":[]}]},{"data":{"id":"dhdqs2wm26g0","created":1774632672246,"text":"布尔类型的定义","expandState":"collapse","layout_right_offset":{"x":282.2499817349028,"y":-105.49999771267181}},"children":[{"data":{"id":"dhdqt7ujjog0","created":1774632761369,"text":"直接定义：agree = True/False"},"children":[]},{"data":{"id":"dhdqt8j9qfk0","created":1774632762865,"text":"比较运算符定义：agree  = 5 > 1 / 5 < 1,\n也就是说一个比较运算表达式就是True或false"},"children":[]}]}]},{"data":{"id":"dh7sgjgyu740","created":1774028050416,"text":"第二章节","expandState":"expand","layout_mind_offset":{"x":165.2499987818302,"y":-639.7499735765166}},"children":[{"data":{"id":"dh7slutitug0","created":1774028466940,"text":"字面量:一种文本，数字，字符等","expandState":"expand","layout_right_offset":{"x":225.24999423697614,"y":-36.749999221414384}},"children":[{"data":{"id":"dh7spvyewa80","created":1774028782869,"text":"              整数（int）\n\t          浮点数（float）\n数字： \n\t          复数（complex）\n\t          布尔（bool）      ","layout_right_offset":{"x":449.99998658895515,"y":-126.99999621510517}},"children":[]},{"data":{"id":"dh7sriur8p40","created":1774028911078,"text":"集合：无需不重复集合","layout_right_offset":{"x":487.9999854564671,"y":-60.99999818205845}},"children":[]},{"data":{"id":"dh7srqh1ajk0","created":1774028927663,"text":"字典：无序Key-Value集合","layout_right_offset":{"x":517.9999845623976,"y":-43.99999868869793}},"children":[]},{"data":{"id":"dheymobu4cw0","created":1774756377530,"text":"序列类型","layout_right_offset":{"x":413.99998766183876,"y":-9.999999701976776},"expandState":"expand"},"children":[{"data":{"id":"dh7spyxfbo00","created":1774028789340,"text":"字符串：描述文本"},"children":[]},{"data":{"id":"dh7sq1d039c0","created":1774028794635,"text":"列表:有序可变序列"},"children":[]},{"data":{"id":"dh7srcef52g0","created":1774028897030,"text":"元组：有序不可变序列"},"children":[]}]}]},{"data":{"id":"dh7sve4urh40","created":1774029214262,"text":"注释","layout_right_offset":{"x":356.24999189749303,"y":207.49999273568386},"expandState":"collapse"},"children":[{"data":{"id":"dh7svty6neo0","created":1774029248687,"text":"单行注释","layout_right_offset":{"x":259.99999225139646,"y":-11.999999642372018},"expandState":"expand"},"children":[{"data":{"id":"dh7sw5npyco0","created":1774029274176,"text":"# 注释内容","layout_right_offset":{"x":223.99999332428,"y":-0.9999999701976776}},"children":[]}]},{"data":{"id":"dh7svuhrhbs0","created":1774029249872,"text":"多行注释","layout_right_offset":{"x":267.9999920129781,"y":-6.999999791383857},"expandState":"expand"},"children":[{"data":{"id":"dh7sx2opx6g0","created":1774029346070,"text":"\"\"\"  注释内容 \"\"\"","layout_right_offset":{"x":260.9999922215941,"y":5.684341886080802e-14}},"children":[]}]}]},{"data":{"id":"dh7sxzj0cts0","created":1774029417558,"text":"用type()查看数据类型","layout_right_offset":{"x":266.49999455362547,"y":-158.49999516457336}},"children":[]},{"data":{"id":"dh7szkrkppc0","created":1774029542153,"text":"数据类型转换","layout_right_offset":{"x":299.74999339506047,"y":-127.24999626353423},"expandState":"collapse"},"children":[{"data":{"id":"dh7t0me4alc0","created":1774029624057,"text":"注意","layout_right_offset":{"x":220.99999341368698,"y":1.1368683772161603e-13},"expandState":"expand"},"children":[{"data":{"id":"dh7t0q4szd40","created":1774029632201,"text":"任何字面量均可转换为字符串str()","layout_right_offset":{"x":375.99998879432695,"y":-5.999999821186066}},"children":[]},{"data":{"id":"dh7t0rmiwnc0","created":1774029635449,"text":"只有数文本可以转换为整型int()，float()","layout_right_offset":{"x":419.9999874830248,"y":-1.9999999403953552}},"children":[]}]}]},{"data":{"id":"dh7t8sdvqaw0","created":1774030264017,"text":"字符串扩展","layout_right_offset":{"x":-508.99998058378776,"y":-323.00000029802334},"expandState":"expand"},"children":[{"data":{"id":"dhbpiwupivs0","created":1774426012770,"text":"字符串的三种定义方式","expandState":"collapse","layout_right_offset":{"x":-331.99999010562914,"y":-180.99999460577982}},"children":[{"data":{"id":"dhcjfx5295c0","created":1774510411601,"text":"'单引号定义'"},"children":[]},{"data":{"id":"dhcjfz5svs00","created":1774510415999,"text":"\"双引号定义\""},"children":[]},{"data":{"id":"dhcjfznxktk0","created":1774510417095,"text":"\"\"\"三个双引号定义\"\"\"","expandState":"collapse"},"children":[{"data":{"id":"dhcjh7mwx8o0","created":1774510512812,"text":"与多行注释一样，支持换行操作，\n用变量接受就是字符串，不接收就是注释"},"children":[]}]}]},{"data":{"id":"dhbpizqunfs0","created":1774426019067,"text":"字符串的拼接","expandState":"collapse","layout_right_offset":{"x":-356.9999893605708,"y":-153.99999541044247}},"children":[{"data":{"id":"dhcjie87yt40","created":1774510605525,"text":"用 + 连接两个字符串(不同类型之间不能直接拼接，\n可以利用格式化转换为字符串再拼接)"},"children":[]},{"data":{"id":"dhcjimlgt600","created":1774510623740,"text":"格式化%拼接"},"children":[]}]},{"data":{"id":"dhbpj0xpv1k0","created":1774426021659,"text":"字符串的格式化","expandState":"collapse","layout_right_offset":{"x":-354.99998942017567,"y":-96.99999710917496}},"children":[{"data":{"id":"dhcrxm4st8o0","created":1774534367074,"text":"利用%"},"children":[]},{"data":{"id":"dhcrzyiheg00","created":1774534550752,"text":"利用f\"这是第一个字符处串{},这是第二个{}\""},"children":[]}]},{"data":{"id":"dhcjfmxcbfk0","created":1774510389366,"text":"对表达式的格式化","expandState":"collapse","layout_right_offset":{"x":-383.99998855590866,"y":-82.99999752640747}},"children":[{"data":{"id":"dhcs2sm9cdc0","created":1774534773012,"text":"%(表达式)"},"children":[]}]},{"data":{"id":"dhbpl65r2wo0","created":1774426189757,"text":"字符串格式化的精度控制(用于浮点数)","expandState":"collapse","layout_right_offset":{"x":-434.9999870359899,"y":-64.99999806284882}},"children":[{"data":{"id":"dhcs40xizls0","created":1774534869471,"text":"%m.nf → m控制宽度，n控制保留几位小数"},"children":[]}]}]},{"data":{"id":"dh7t2e3v1x40","created":1774029762751,"text":"标识符：起名字","layout_right_offset":{"x":315.7499916516243,"y":-256.99998816847835},"expandState":"collapse"},"children":[{"data":{"id":"dh7t38ikwlk0","created":1774029828944,"text":"变量","layout_right_offset":{"x":385.9999884963041,"y":-25.99999922513996}},"children":[]},{"data":{"id":"dh7t39vrmz40","created":1774029831918,"text":"类","layout_right_offset":{"x":425.999987304211,"y":-13.999999582767487}},"children":[]},{"data":{"id":"dh7t3dkuz1k0","created":1774029839966,"text":"方法","layout_right_offset":{"x":435.9999870061879,"y":-13.999999582767487}},"children":[]},{"data":{"id":"dh7t5ry17io0","created":1774030027966,"text":"规则：只允许出现英文，中文，数字，下划线(_)\n不推荐中文，数字不可开头，不能用关键字","layout_right_offset":{"x":479.9999856948857,"y":-18.99999943375559}},"children":[]}]},{"data":{"id":"dhcs5vhv5480","created":1774535014369,"text":"数据的输入(input语句)","layout_right_offset":{"x":-531.4999787583954,"y":-375.4999869838365},"expandState":"collapse"},"children":[{"data":{"id":"dhcs6dymda80","created":1774535054564,"text":"name = input(请输入你的名字)","layout_right_offset":{"x":-76.99999770522118,"y":60.99999818205845}},"children":[]},{"data":{"id":"dhdoe48yq3s0","created":1774625935852,"text":"注意:你输入的任何字面量都\n是字符串，即“input(请输入你的名字)”\n是一个字符串变量","layout_right_offset":{"x":-88.99999734759339,"y":-83.9999974966048},"priority":"1","background":"#ffffff","color":"#ff0000"},"children":[]}]}]},{"data":{"id":"dhehlom2doo0","created":1774708340916,"text":"第四章","layout_mind_offset":{"x":500.41664478886526,"y":249.3333216971825}},"children":[{"data":{"id":"dhehn0ms1740","created":1774708445445,"text":"while循环","layout_right_offset":{"x":632.4999717250477,"y":-83.74999625608314}},"children":[{"data":{"id":"dhehskridb40","created":1774708881088,"text":"格式👇\nwhile 条件：\n.         操作1\n.         操作2","layout_right_offset":{"x":401.2499820627281,"y":-54.99999754130829}},"children":[]},{"data":{"id":"dhehv6277ts0","created":1774709084175,"text":"嵌套使用","layout_right_offset":{"x":316.24998586252406,"y":-2.4999998882411774}},"children":[]}]},{"data":{"id":"dhehn1e47hc0","created":1774708447098,"text":"for循环","layout_right_offset":{"x":641.4999713823208,"y":-8.749999757856017}},"children":[{"data":{"id":"dhehu0mkkk80","created":1774708993982,"text":"基础语法👇\nfor 临时变量 in 待处理数据(序列类型) :\n.     操作","layout_right_offset":{"x":428.74998083338255,"y":48.74999782070552},"expandState":"expand"},"children":[]},{"data":{"id":"dhehx8hd1ao0","created":1774709246173,"text":"for循环语句会将数据一个个取出赋值给变量","layout_right_offset":{"x":546.2499755807228,"y":-104.99999530613411},"priority":"1","font-family":"微软雅黑,Microsoft YaHei","color":"#ff0000"},"children":[]},{"data":{"id":"dhf06cjrzrs0","created":1774760740282,"text":"range语句的三种定义方式[左闭右开)","layout_right_offset":{"x":550.9999835789208,"y":14.999999552965107}},"children":[{"data":{"id":"dhf09493ya80","created":1774760957316,"text":"for x in range(n) :（依次将0~n-1赋值给x）","layout_right_offset":{"x":582.9999826252466,"y":-59.99999821186066}},"children":[]},{"data":{"id":"dhf0957wfe00","created":1774760959419,"text":"for x in range(m,n) :（依次将m~n-1赋值给x）","layout_right_offset":{"x":585.9999825358395,"y":-19.999999403953552}},"children":[]},{"data":{"id":"dhf095msdg80","created":1774760960319,"text":"for x in range(m,n,t) :（从m开始每隔t个步长取值赋值给x）","layout_right_offset":{"x":672.9999799430377,"y":2.999999910592919}},"children":[]}]},{"data":{"id":"dhf0cq5l52o0","created":1774761240084,"text":"continue和break","layout_right_offset":{"x":475.9999858140949,"y":41.99999874830257}},"children":[]}]}]},{"data":{"id":"dhgw8aod9mg0","created":1774952728408,"text":"函数","expandState":"expand"},"children":[{"data":{"id":"dhgw8o1b27c0","created":1774952757489,"text":"函数的定义语法：\ndef 函数名(参数) :\n.     操作一\n.     操作二\n.     return  变量","layout_left_offset":{"x":-164.16665525072182,"y":-94.99999339381893}},"children":[]},{"data":{"id":"dhgwcp1fsh40","created":1774953073130,"text":"函数的None类型","layout_left_offset":{"x":-190.8333075460473,"y":17.499998783071845}},"children":[{"data":{"id":"dhgwn6yqo4w0","created":1774953895791,"text":"平常所说的无返回值函数返回的其实是字面量None\n也可以人为的写上 return+具体结果 改变返回的值","layout_left_offset":{"x":-149.50000191231572,"y":-34.99999756614375}},"children":[]},{"data":{"id":"dhgwntd6nhk0","created":1774953944553,"text":"None等价于False\nnot None等价于True\n可以与判断语句配合","layout_left_offset":{"x":-156.66665577226263,"y":25.833331536915637}},"children":[]},{"data":{"id":"dhgwqcieprk0","created":1774954142957,"text":"用于声明无初始值的变量","layout_left_offset":{"x":-135.83332388765336,"y":74.16666150920952}},"children":[]}]},{"data":{"id":"dhgws3zqpls0","created":1774954281142,"text":"函数的说明文档\n调用函数时","layout_left_offset":{"x":-156.66665577226286,"y":184.1666538599468}},"children":[{"data":{"id":"dhgwsewu9740","created":1774954304911,"text":"def 函数名(形参1，形参2) :\n\t\"\"\"\n.    :param 形参1:  形参1说明\n.    :param 形参2:  形参2说明\n...\n.    :return:返回值的说明\n\t \"\"\"","layout_left_offset":{"x":-129.16665768457813,"y":-17.499998783071987}},"children":[]}]}]}]},"template":"default","theme":"snow","version":"1.4.43"}